# Local-first SQLite database. Do not commit real .env files.
DATABASE_URL="file:./dev.db"
# Optional public wallet addresses to sync from the integrations popup. Format: chain:address separated by commas or newlines.
# Supported chains: bitcoin, ethereum, solana, sui. Public addresses only; never private keys/seed phrases.
CRYPTO_PUBLIC_ADDRESSES=""
# Optional Etherscan API key for higher-rate Ethereum reads. Public-address only; never private keys/seed phrases.
ETHERSCAN_API_KEY=""
# Optional Interactive Brokers Flex Web Service read-only reporting credentials. Keep only in local .env.
IBKR_FLEX_TOKEN=""
IBKR_FLEX_QUERY_ID=""
# 32-byte base64 key for future encrypted secret storage if tokens are added.
LOCAL_SECRET_ENCRYPTION_KEY=""
